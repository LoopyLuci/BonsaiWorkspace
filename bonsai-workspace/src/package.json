{
  "name": "bonsai-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test:agent-api": "node ./agent-api-smoke.mjs",
    "test:agent-api:remote-only": "set BONSAI_SKIP_UI=1&& node ./agent-api-smoke.mjs",
    "test:agent-ui-hitl": "set BONSAI_SKIP_API=1&& node ./agent-api-smoke.mjs",
    "test:agent-ui-live": "set BONSAI_SKIP_API=1&& set BONSAI_UI_LIVE=1&& node ./agent-api-smoke.mjs",
    "test:agent-ui-live-orchestrated": "node ./agent-ui-live-orchestrated.mjs",
    "launch:all": "node ./launch-all.mjs",
    "launch:desktop": "node ./launch-all.mjs --mode desktop",
    "launch:desktop+usb": "node ./launch-all.mjs --mode desktop+usb",
    "launch:preflight": "node ./launch-all.mjs --preflight-only",
    "launch:preflight:report": "node ./launch-all.mjs --preflight-only --report-path ../../tool_test/launcher/preflight.json",
    "test:android-usb-regression": "node ./android-usb-regression.mjs",
    "evidence:append-usb-ledger": "pwsh -File ./append-usb-evidence-ledger.ps1",
    "test:bonsai-live-testing-feature": "set BONSAI_LIVE_MODE=1&& set BONSAI_LIVE_HEADLESS=0&& node ./bonsai-live-testing-feature.mjs",
    "test:bonsai-live-testing-feature:watch": "set BONSAI_LIVE_MODE=1&& set BONSAI_LIVE_HEADLESS=0&& set BONSAI_LIVE_SLOW_MO_MS=180&& set BONSAI_LIVE_SCENARIO_PAUSE_MS=1800&& set BONSAI_UI_KEEP_OPEN_MS=30000&& node ./bonsai-live-testing-feature.mjs",
    "test:bonsai-live-testing-feature:headless": "set BONSAI_LIVE_MODE=0&& set BONSAI_LIVE_HEADLESS=1&& node ./bonsai-live-testing-feature.mjs",
    "demo:app-window-live": "node ./agent-app-window-live.mjs",
    "test:agent-all": "node ./agent-api-smoke.mjs",
    "test:agent-orchestrated": "node ./agent-orchestrate-all.mjs",
    "test:agent-routing-ci": "node ./agent-routing-ci.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-barcode-scanner": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "dompurify": "^3.0.6",
    "monaco-editor": "^0.45.0",
    "playwright": "^1.59.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "@tsconfig/svelte": "^5.0.0",
    "@types/node": "^25.6.0",
    "svelte": "^4.2.0",
    "svelte-check": "^3.6.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^4.1.4"
  }
}
