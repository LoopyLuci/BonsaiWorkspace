{
  "productName": "bonsai-workspace",
  "version": "0.1.0",
  "identifier": "com.bonsai.workspace",
  "build": {
    "beforeDevCommand": "npm --prefix Z:\\Projects\\BonsaiWorkspace\\bonsai-workspace\\src run dev",
    "beforeBuildCommand": "npm --prefix Z:\\Projects\\BonsaiWorkspace\\bonsai-workspace\\src run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bonsai Workspace",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' blob: 'unsafe-inline'; style-src 'self' 'unsafe-inline'; worker-src 'self' blob:; child-src 'self' blob:; font-src 'self' data:; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
