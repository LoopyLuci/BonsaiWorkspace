{
  "name": "bonsai-everywhere",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "build:chrome": "vite build && node ./scripts/build-manifest.mjs chrome",
    "build:firefox": "vite build && node ./scripts/build-manifest.mjs firefox",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tsconfig/svelte": "^5.0.4",
    "@types/chrome": "^0.0.276",
    "@types/node": "^22.10.2",
    "@types/webextension-polyfill": "^0.12.1",
    "svelte": "^4.2.19",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
