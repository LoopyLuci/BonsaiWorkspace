{
  "manifest_version": 3,
  "name": "Bonsai Everywhere",
  "version": "0.1.0",
  "description": "In-browser access to Bonsai Buddy and Bonsai Workspace.",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "omnibox"
  ],
  "optional_permissions": [
    "tabs",
    "bookmarks",
    "downloads"
  ],
  "host_permissions": [
    "http://127.0.0.1:*/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Bonsai Everywhere",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "omnibox": {
    "keyword": "bonsai"
  },
  "commands": {
    "open-workspace": {
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      },
      "description": "Open Bonsai Workspace"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
