{:min-bb-version "1.3.190"
 :tasks
 {:launch-preflight
  {:doc "Run Bonsai launcher preflight checks and write report (Babashka phase-1)."
    :task (shell "bb" "run" "bb-launch-preflight.clj")}

  :launch-preflight-report
  {:doc "Run preflight and write report to tool_test/launcher/preflight-bb.json"
    :task (shell "bb" "run" "bb-launch-preflight.clj" "--report" "tool_test/launcher/preflight-bb.json")}

  :api-smoke
  {:doc "Run existing API smoke test through Babashka task wrapper"
   :task (shell "node" "bonsai-workspace/src/agent-api-smoke.mjs")}}}
